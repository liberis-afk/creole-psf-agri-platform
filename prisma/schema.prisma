// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FarmRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum SoilType {
  ARGILEUX
  SABLEUX
  LIMONEUX
  CALCAIRE
  HUMIFERE
  AUTRE
}

enum CultureStatus {
  EN_COURS
  TERMINEE
  ABANDONNEE
}

enum ActiviteType {
  PLANTATION
  IRRIGATION
  APPLICATION
  CULTIVATION
  RECOLTE
}

enum SaisonStatus {
  EN_COURS
  TERMINEE
}

enum TaskStatus {
  A_FAIRE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum InventoryCategory {
  SEMENCE
  ENGRAIS
  CARBURANT
  MATERIEL
  AUTRE
}

enum TransactionType {
  DEPENSE
  REVENU
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum EquipementStatus {
  OPERATIONNEL
  EN_PANNE
  EN_MAINTENANCE
  HORS_SERVICE
}

enum WorkOrderType {
  REPARATION
  MAINTENANCE_PREVENTIVE
  INSPECTION
}

enum WorkOrderStatus {
  OUVERT
  EN_COURS
  TERMINE
  ANNULE
}

enum Priorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

// --- Auth.js models ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Core domain models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  memberships        Membership[]
  sentInvitations    Invitation[]
  activitesCreees    Activite[]
  workOrdersAssignes WorkOrder[]
}

/// Isole chaque ferme : chaque utilisateur appartient à une ou plusieurs fermes via Membership.
model Farm {
  id        String   @id @default(cuid())
  name      String
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  parcelles    Parcelle[]
  inventory    InventoryItem[]
  transactions Transaction[]
  invitations  Invitation[]
  saisons      Saison[]
  equipements  Equipement[]
}

model Membership {
  id        String   @id @default(cuid())
  role      FarmRole @default(EMPLOYEE)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([userId, farmId])
}

model Parcelle {
  id        String    @id @default(cuid())
  name      String
  latitude  Float?
  longitude Float?
  soilType  SoilType?
  area      Float? // hectares
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  cultures Culture[]
  tasks    Task[]
}

model Culture {
  id         String        @id @default(cuid())
  parcelleId String
  parcelle   Parcelle      @relation(fields: [parcelleId], references: [id], onDelete: Cascade)
  saisonId   String?
  saison     Saison?       @relation(fields: [saisonId], references: [id], onDelete: SetNull)
  nomCulture String
  variete    String?
  dateDebut  DateTime?
  dateFin    DateTime?
  statut     CultureStatus @default(EN_COURS)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  activites Activite[]
  tasks     Task[]

  @@index([parcelleId, statut])
}

model Activite {
  id          String       @id @default(cuid())
  cultureId   String
  culture     Culture      @relation(fields: [cultureId], references: [id], onDelete: Cascade)
  type        ActiviteType
  date        DateTime
  notes       String?
  quantite    Float?
  unite       String?
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([cultureId])
  @@index([type])
}

model Saison {
  id        String       @id @default(cuid())
  farmId    String
  farm      Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  nom       String
  annee     Int
  dateDebut DateTime?
  dateFin   DateTime?
  statut    SaisonStatus @default(EN_COURS)
  createdAt DateTime     @default(now())

  cultures Culture[]

  @@index([farmId, statut])
}

model Task {
  id        String     @id @default(cuid())
  title     String
  notes     String?
  dueDate   DateTime?
  status    TaskStatus @default(A_FAIRE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  parcelId String?
  parcel   Parcelle? @relation(fields: [parcelId], references: [id], onDelete: Cascade)

  cropId String?
  crop   Culture? @relation(fields: [cropId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id        String            @id @default(cuid())
  name      String
  category  InventoryCategory
  quantity  Float
  unit      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  role      FarmRole
  status    InvitationStatus @default(PENDING)
  token     String           @unique
  expiresAt DateTime
  createdAt DateTime         @default(now())

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation(fields: [invitedById], references: [id])

  @@index([email])
  @@index([farmId, status])
}

model Equipement {
  id              String           @id @default(cuid())
  farmId          String
  farm            Farm             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  identifiant     String
  nom             String
  type            String?
  statut          EquipementStatus @default(OPERATIONNEL)
  dateAcquisition DateTime?
  createdAt       DateTime         @default(now())

  workOrders WorkOrder[]

  @@unique([farmId, identifiant])
  @@index([farmId])
}

model WorkOrder {
  id            String          @id @default(cuid())
  equipementId  String
  equipement    Equipement      @relation(fields: [equipementId], references: [id], onDelete: Cascade)
  type          WorkOrderType
  description   String
  statut        WorkOrderStatus @default(OUVERT)
  priorite      Priorite        @default(NORMALE)
  dateOuverture DateTime        @default(now())
  dateCloture   DateTime?
  coutEstime    Float?
  coutReel      Float?
  createdAt     DateTime        @default(now())

  assigneAId String?
  assigneA   User?   @relation(fields: [assigneAId], references: [id])

  @@index([equipementId, statut])
}
