DATABASE_URL="postgresql://user:password@localhost:5432/creole_psf_agri?schema=public"

AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Assistant IA (module intelligence artificielle) — clé depuis console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Invitations par email — envoyées via votre compte Gmail (SMTP)
# Générez un mot de passe d'application sur myaccount.google.com/apppasswords
# (nécessite la validation en deux étapes activée sur le compte)
GMAIL_USER="votre-adresse@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# URL publique de l'app, utilisée dans les liens d'invitation (optionnel en production sur Vercel)
APP_URL="http://localhost:3000"
